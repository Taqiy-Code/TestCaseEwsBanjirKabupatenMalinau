generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sensor {
  id                String    @id
  name              String
  location          String
  siaga_threshold   Float
  waspada_threshold Float
  awas_threshold    Float
  readings          SensorReading[]
}

model SensorReading {
  id        String   @id @default(uuid())
  sensor_id String
  value     Float
  unit      String

  timestamp DateTime

  sensor Sensor @relation(fields: [sensor_id], references: [id])
  
  @@index([sensor_id, timestamp])
}